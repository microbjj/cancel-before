generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELED
  TRIAL
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PlanTier {
  FREE
  PRO
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum NotificationChannel {
  EMAIL
  PUSH
}

enum WebhookProvider {
  STRIPE
}

enum Role {
  USER
  ADMIN
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  passwordHash     String?
  role             Role              @default(USER)
  lastSeenIp       String?
  lastSeenDevice   String?
  timezone         String            @default("UTC")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  subscriptions    Subscription[]
  reminderRules    ReminderRule[]
  notificationLogs NotificationLog[]
  payments         Payment[]
  userPlan         UserPlan?
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String
  name                   String
  status                 SubscriptionStatus @default(ACTIVE)
  billingCycle           BillingCycle       @default(MONTHLY)
  amountCents            Int?
  currency               String             @default("USD")
  providerCustomerId     String?
  providerSubscriptionId String?            @unique
  cancelByAt             DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminderRules          ReminderRule[]
  notificationLogs       NotificationLog[]
  payments               Payment[]

  @@index([userId])
  @@index([status])
}

model ReminderRule {
  id             String            @id @default(cuid())
  userId         String
  subscriptionId String
  daysBefore     Int
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription      @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  notifications  NotificationLog[]

  @@index([userId])
  @@index([subscriptionId])
}

model NotificationLog {
  id             String              @id @default(cuid())
  userId         String
  subscriptionId String?
  reminderRuleId String?
  channel        NotificationChannel
  sentAt         DateTime?
  createdAt      DateTime            @default(now())
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription?       @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  reminderRule   ReminderRule?       @relation(fields: [reminderRuleId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subscriptionId])
}

model UserPlan {
  id        String    @id @default(cuid())
  userId    String    @unique
  tier      PlanTier  @default(FREE)
  startsAt  DateTime  @default(now())
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  subscriptionId String?
  provider       String        @default("stripe")
  providerRef    String?       @unique
  amountCents    Int
  currency       String        @default("USD")
  status         PaymentStatus @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subscriptionId])
}

model WebhookEvent {
  id              String          @id @default(cuid())
  provider        WebhookProvider @default(STRIPE)
  externalEventId String          @unique
  eventType       String
  payload         Json
  receivedAt      DateTime        @default(now())
  processedAt     DateTime?
  createdAt       DateTime        @default(now())

  @@index([provider])
  @@index([receivedAt])
}
